APP_NAME=Court File Indexer Backend
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
SECRET_KEY=change-me

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=court_indexer
POSTGRES_USER=court_user
POSTGRES_PASSWORD=court_pass

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=court_documents
EMBEDDING_VECTOR_SIZE=1024
QDRANT_TOP_K=8
CHAT_CONTEXT_TOP_K=6
CHAT_MAX_HISTORY=12
CHAT_GENERATION_TIMEOUT_SECONDS=45

STORAGE_ROOT=/app/storage
PDF_STORAGE_DIR=/app/storage/pdfs
RENDER_STORAGE_DIR=/app/storage/rendered
OCR_STORAGE_DIR=/app/storage/ocr
EXPORT_STORAGE_DIR=/app/storage/exports
LOG_STORAGE_DIR=/app/storage/logs
MAPPING_SHEET_PATH=/app/storage/config/document_mapping.xlsx
MAPPING_SHEET_NAME=Sheet1
MAPPING_REFRESH_SECONDS=60

DEFAULT_INDEX_SCAN_START=1
DEFAULT_INDEX_SCAN_END=10
DEFAULT_BATCH_CHUNK_SIZE=10
DEFAULT_QUEUE_NAME=index_queue
TASK_HEARTBEAT_SECONDS=30
STUCK_TASK_SECONDS=900

OCR_ENGINE=paddle
OCR_LANGUAGES=en,hi
OCR_USE_ANGLE_CLS=true
OCR_RENDER_DPI=220
OCR_RENDER_FORMAT=png
INDEX_MIN_CANDIDATE_SCORE=2.0
INDEX_CONTINUATION_MIN_SCORE=1.2
ENABLE_HINDI_FALLBACK=true
ENABLE_CONTENT_GENERATED_INDEX_FALLBACK=true
TESSERACT_CMD=tesseract

USE_VLM_FALLBACK=true
ENABLE_CHAT=true
ENABLE_QDRANT=true

LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LOCAL_CHAT_MODEL=Qwen/Qwen2.5-3B-Instruct
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
